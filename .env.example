# ── Copier en ".env" et remplir. Sur Railway : mettre ces valeurs dans Variables ──

# Port (Railway le fournit automatiquement)
PORT=3000

# URL publique du serveur (pour les retours de paiement HelloAsso)
SERVER_URL=http://localhost:3000

# Clé secrète JWT — METTRE UNE VALEUR LONGUE ET ALÉATOIRE EN PRODUCTION
JWT_SECRET=changez-cette-cle-secrete-aleatoire

# Compte admin initial (créé au premier démarrage ; défaut: admin / admin123)
ADMIN_EMAIL=admin

# ── Stockage persistant (Railway : pointer vers le volume monté) ──────────────
# Ex. si le volume est monté sur /data :
#   DATA_DIR=/data/db
#   UPLOAD_DIR=/data/uploads
DATA_DIR=
UPLOAD_DIR=

# ── EMAIL (Gmail : créer un "mot de passe d'application") ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=mot_de_passe_application
MANAGER_EMAIL=responsable@bethmenahem.fr

# ── WHATSAPP du régisseur (format international, sans + ni espaces) ───────────
# Ex : 06 12 34 56 78 → 33612345678
REGISSEUR_WHATSAPP=33612345678

# ── HELLOASSO (paiement en ligne) ────────────────────────────────────────────
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_ORG_SLUG=
